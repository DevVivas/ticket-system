{
  "info": {
    "name": "ms-auth",
    "description": "Coleccion de endpoints del microservicio ms-auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST /api/auth/register",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"juan123\",\n  \"password\": \"password123\",\n  \"email\": \"juan@example.com\",\n  \"rol\": \"ADMIN\"\n}"
        }
      }
    },
    {
      "name": "POST /api/auth/login",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"juan123\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "POST /api/auth/validate",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/api/auth/validate",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "validate"]
        },
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ]
}
